# Production static build Dockerfile for Vite
# Builds static files to /app/out directory
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY frontend .

# Note: Build runs at container runtime via docker-compose command
# This allows the volume mount to capture the output in ../frontend/out
