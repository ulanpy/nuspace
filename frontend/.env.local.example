# Vite Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# Client-side environment variables
# =============================================================================
# Vite exposes variables that start with `VITE_` via `import.meta.env`.
# =============================================================================

# Base URL for the application (used for HMR/WebSocket in development)
# In Docker development, this is automatically set by the start script
VITE_BASE_URL=http://localhost:5173

# Enable/disable seasonal snowfall animation (default: true)
# Set to "false" to disable
VITE_ENABLE_SNOWFALL=true

# Google Cloud Storage bucket name (if applicable)
# VITE_GCS_BUCKET=your-bucket-name

# API URL (typically not needed as /api is proxied by nginx)
# VITE_API_URL=/api
